# IONOS OpenShift Scaling Tool — environment configuration
# Copy this file to .env and fill in your values.
# .env is never committed to source control.

# OpenShift cluster API endpoint (port 6443)
OCP_CLUSTER_API_URL=https://api.your-cluster.example.com:6443

# OpenShift bearer token — obtain with: oc whoami -t
# Tokens expire; update this when you get a 401 in the tool.
# Leave blank to use the "Get Token" button in the UI (requires management host + credentials below).
OCP_BEARER_TOKEN=

# OpenShift cluster admin username — used by the "Get Token" button to run
#   oc login -u $OCP_ADMIN_USERNAME -p $OCP_ADMIN_PASSWORD $OCP_CLUSTER_API_URL
# on the management host via SSH, then return the resulting bearer token.
OCP_ADMIN_USERNAME=

# OpenShift cluster admin password — paired with OCP_ADMIN_USERNAME above.
# Only transmitted to your own management host over SSH; never stored by the tool.
OCP_ADMIN_PASSWORD=

# Public IP or hostname of the OpenShift management / bastion host
OCP_MGMT_HOST=

# SSH private key for the management host (PEM format, all on one line won't
# work — use the multi-line format below, or leave blank to paste in the UI).
# Tip: paste the full key contents including the BEGIN/END header lines. 
# Insert \n at the end of each line in place of a carriage return
OCP_MGMT_HOST_SSH_KEY=

# SSH private key for worker nodes (used to monitor installation progress).
# Must be the key embedded in the worker MachineConfig (core user authorized_keys).
# Check with: oc get mc rendered-worker-... -o json | jq '.spec.config.passwd.users'
# Same multi-line PEM format as above. If omitted, installation runs unmonitored.
OCP_WORKER_SSH_KEY=

# IONOS Cloud API token (from the IONOS DCD → API Keys)
IONOS_API_TOKEN=

# IONOS FTP credentials — used only for uploading custom images (e.g. RHCOS) and the
# agent installer ISO when installing a new cluster.
# These are your IONOS DCD account email + password, NOT the API token.
# FTP upload server: ftp-{region}.ionos.com (region auto-detected from datacenter location).
IONOS_FTP_USER=
IONOS_FTP_PASS=

# Red Hat pull secret — used by the "Install New Cluster" wizard to authenticate with
# Red Hat registries during OpenShift installation.
# Obtain from: https://console.redhat.com/openshift/install/pull-secret
# Paste the full JSON value (everything from the outer { to the closing }).
RH_PULL_SECRET=

# Default hostname prefix for new worker nodes (pre-fills the Server Name field).
# You still need to set the final name/number in the UI before creating the server.
# Example: "compute-" would pre-fill "compute-" ready for you to append "2", "3" etc.
OCP_WORKER_NAME_PREFIX=

# DNS servers embedded into the bootstrap ISO NM keyfile.
# Must resolve api-int.<cluster-domain> — use the same DNS as your existing worker nodes
# (check: oc debug node/<worker> -- chroot /host cat /etc/resolv.conf)
# IONOS default: 212.227.123.16;212.227.123.17; (semicolon-separated NM keyfile format)
OCP_BOOTSTRAP_DNS=212.227.123.16;212.227.123.17;

# NAT Gateway IP for the private worker LAN — sits at the .1 address of the subnet.
# IONOS private LAN DHCP provides an IP but no default route, so we embed it manually.
OCP_BOOTSTRAP_GATEWAY=

# CIDR prefix length for the worker private LAN subnet (used for static IP NMState config).
# Match the prefix of your IONOS private LAN (e.g. 23 for 10.7.224.0/23, 24 for 10.7.224.0/24).
OCP_BOOTSTRAP_PREFIX_LENGTH=24

# ── Container Registry ─────────────────────────────────────────────────────
# These pre-fill the registry fields in the "Deploy IONOS Machine API provider"
# section of the autoscaler wizard.  They are only used when you tick the
# "Deploy provider" checkbox during first-time setup.

# Registry type — one of: dockerhub | ghcr | ionos | custom
REGISTRY_TYPE=dockerhub

# Full image reference for the IONOS Machine API provider container.
# Docker Hub:  username/repo:tag
# GHCR:        ghcr.io/username/repo:tag
# IONOS / custom: full URL including registry host
REGISTRY_IMAGE=paulmcc50/myrepo:ionos-machine-api-provider

# Registry credentials (leave blank for public images)
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Optional: override the default port (default: 3000)
# PORT=3000

# Optional: password-protect the server-side .env auto-fill.
# Set AUTH_CONTRACT_ID to a contract/account identifier shown in the password prompt.
# Set AUTH_PASSWORD_HASH to a bcrypt hash of your chosen password.
# Generate with: node -e "require('bcryptjs').hash('yourpassword',10).then(h=>console.log(h))"
# Leave both blank to disable password protection.
AUTH_CONTRACT_ID=
AUTH_PASSWORD_HASH=
